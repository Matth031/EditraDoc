{
  "name": "editify",
  "version": "1.1.1",
  "private": true,
  "description": "Local-first PDF desktop app foundation",
  "main": "src/main/main.js",
  "scripts": {
    "predev": "node scripts/write-build-info.mjs",
    "postinstall": "node scripts/copy-dompurify.mjs",
    "dev": "node scripts/ensure-python-deps.mjs && electron .",
    "setup:python": "node scripts/ensure-python-deps.mjs",
    "start": "electron .",
    "test": "node scripts/run-python-tests.mjs",
    "test:verify-assets": "node scripts/verify-05-dev-assets.mjs",
    "lint": "eslint e2e scripts node-tests src/main src/lib/session-log-store.js src/lib/page-rotate-math.js src/lib/update-manifest.js src/renderer/renderer-error-log.js src/renderer/mani-color-picker.js src/renderer/floating-panel-drag.js src/renderer/renderer-text-html.js src/renderer/renderer-text-ctx.js src/renderer/renderer-utils.js src/renderer/renderer-toast.js src/renderer/renderer-session-log.js src/renderer/renderer-session-log-ui.js src/renderer/renderer-log-settings-ui.js src/renderer/renderer-update-ui.js src/renderer/renderer-i18n-apply.js src/renderer/renderer-e2e-helpers.js src/renderer/renderer-sidebars.js src/renderer/renderer-text-ctx-menu.js src/renderer/renderer-shape-image-ctx-menu.js src/renderer/renderer-split-workspace.js src/renderer/renderer-jobs.js src/renderer/renderer-html-convert.js src/renderer/renderer-image-convert.js src/renderer/renderer-page-rotate.js src/renderer/renderer-app-chrome.js src/renderer/renderer-tooltips.js src/renderer/renderer-session.js src/renderer/renderer-pdf-viewer.js src/renderer/renderer-pdf-save.js",
    "format": "prettier --write \"e2e/**/*.js\" \"node-tests/**/*.js\" \"scripts/**/*.mjs\" \"src/main/**/*.js\" \"src/lib/**/*.js\" \"src/renderer/renderer-error-log.js\" \"src/renderer/mani-color-picker.js\" \"src/renderer/floating-panel-drag.js\" \"src/renderer/renderer-text-html.js\" \"src/renderer/renderer-text-ctx.js\" \"src/renderer/renderer-utils.js\" \"src/renderer/renderer-toast.js\" \"src/renderer/renderer-session-log.js\" \"src/renderer/renderer-session-log-ui.js\" \"src/renderer/renderer-log-settings-ui.js\" \"src/renderer/renderer-update-ui.js\" \"src/renderer/renderer-i18n-apply.js\" \"src/renderer/renderer-e2e-helpers.js\" \"src/renderer/renderer-sidebars.js\" \"src/renderer/renderer-text-ctx-menu.js\" \"src/renderer/renderer-shape-image-ctx-menu.js\" \"src/renderer/renderer-split-workspace.js\" \"src/renderer/renderer-jobs.js\" \"src/renderer/renderer-html-convert.js\" \"src/renderer/renderer-image-convert.js\" \"src/renderer/renderer-page-rotate.js\" \"src/renderer/renderer-app-chrome.js\" \"src/renderer/renderer-tooltips.js\" \"src/renderer/renderer-session.js\" \"src/renderer/renderer-pdf-viewer.js\" \"src/renderer/renderer-pdf-save.js\" \"eslint.config.mjs\"",
    "format:check": "prettier --check \"e2e/**/*.js\" \"node-tests/**/*.js\" \"scripts/**/*.mjs\" \"src/main/**/*.js\" \"src/lib/**/*.js\" \"src/renderer/renderer-error-log.js\" \"src/renderer/mani-color-picker.js\" \"src/renderer/floating-panel-drag.js\" \"src/renderer/renderer-text-html.js\" \"src/renderer/renderer-text-ctx.js\" \"src/renderer/renderer-utils.js\" \"src/renderer/renderer-toast.js\" \"src/renderer/renderer-session-log.js\" \"src/renderer/renderer-session-log-ui.js\" \"src/renderer/renderer-log-settings-ui.js\" \"src/renderer/renderer-update-ui.js\" \"src/renderer/renderer-i18n-apply.js\" \"src/renderer/renderer-e2e-helpers.js\" \"src/renderer/renderer-sidebars.js\" \"src/renderer/renderer-text-ctx-menu.js\" \"src/renderer/renderer-shape-image-ctx-menu.js\" \"src/renderer/renderer-split-workspace.js\" \"src/renderer/renderer-jobs.js\" \"src/renderer/renderer-html-convert.js\" \"src/renderer/renderer-image-convert.js\" \"src/renderer/renderer-page-rotate.js\" \"src/renderer/renderer-app-chrome.js\" \"src/renderer/renderer-tooltips.js\" \"src/renderer/renderer-session.js\" \"src/renderer/renderer-pdf-viewer.js\" \"src/renderer/renderer-pdf-save.js\" \"eslint.config.mjs\"",
    "test:spell": "node scripts/spellcheck-smoke.mjs",
    "test:html-convert": "node scripts/run-html-to-pdf-convert.cjs",
    "test:embedded-python": "node scripts/run-embedded-python-smoke.cjs",
    "test:export-regression": "npm test && npx playwright test e2e/app.export-image.spec.js e2e/app.export-annotations-regression.spec.js e2e/app.viewer-text-regression.spec.js e2e/app.page-rotate.spec.js",
    "test:rotate-regression": "node --test node-tests/pdf-viewport-rotation.test.js && npx playwright test e2e/app.page-rotate.spec.js",
    "test:packaged-export": "npx playwright test e2e/app.export-image-packaged.spec.js",
    "test:shape-parity": "node --test node-tests/shape-geometry-parity.test.js",
    "test:node": "node scripts/run-node-tests.mjs",
    "test:coverage": "node scripts/run-node-tests.mjs --coverage",
    "test:coverage:logic": "c8 --include \"src/lib/**/*.js\" node --test \"node-tests/session-log-store.test.js\"",
    "test:audit": "npm audit --audit-level=high",
    "e2e": "playwright test",
    "e2e:diag": "playwright test e2e/diag-pdf-open-console.spec.js",
    "test:all": "npm run test:verify-assets && npm run format:check && npm run lint && npm run test:coverage && npm run test:audit && npm test && npm run test:spell && npm run e2e",
    "build": "electron-builder --dir",
    "dist": "electron-builder",
    "bundle:python-win": "powershell -ExecutionPolicy Bypass -File scripts/bundle-python-embed-win.ps1",
    "prepare:win-icon": "node scripts/generate-win-icon.mjs",
    "dist:win": "node scripts/write-build-info.mjs && npm run prepare:win-icon && npm run bundle:python-win && electron-builder --win && node scripts/copy-installer-to-root.mjs && node scripts/write-latest-manifest.mjs"
  },
  "c8": {
    "all": true,
    "include": [
      "src/main/**/*.js",
      "src/lib/**/*.js"
    ],
    "exclude": [
      "src/main/main.js",
      "src/main/preload.js",
      "src/main/logger.js"
    ],
    "reporter": [
      "text",
      "html"
    ],
    "reports-dir": "coverage",
    "check-coverage": true,
    "lines": 80,
    "functions": 80,
    "branches": 75,
    "statements": 80
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.54.2",
    "c8": "^10.1.3",
    "electron": "^41.2.0",
    "electron-builder": "^26.0.12",
    "eslint": "^10.2.0",
    "eslint-config-prettier": "^10.1.1",
    "globals": "^17.4.0",
    "prettier": "^3.5.3",
    "rcedit": "^5.0.2"
  },
  "build": {
    "appId": "com.manipdf.local",
    "productName": "EditraDoc",
    "icon": "build-resources/icon.ico",
    "afterPack": "scripts/afterPack-set-win-icon.cjs",
    "asar": true,
    "asarUnpack": [
      "python/**/*"
    ],
    "files": [
      "src/**/*",
      "python/**/*",
      "public/**/*",
      "package.json"
    ],
    "directories": {
      "buildResources": "build-resources"
    },
    "win": {
      "icon": "build-resources/icon.ico",
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "signAndEditExecutable": false,
      "verifyUpdateCodeSignature": false,
      "extraResources": [
        {
          "from": "bundle-python/win",
          "to": "python-runtime",
          "filter": [
            "**/*"
          ]
        }
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "perMachine": false,
      "runAfterFinish": true,
      "installerIcon": "build-resources/icon.ico",
      "uninstallerIcon": "build-resources/icon.ico",
      "installerHeaderIcon": "build-resources/icon.ico"
    },
    "linux": {
      "target": "AppImage"
    },
    "mac": {
      "target": "dmg"
    }
  },
  "dependencies": {
    "dictionary-en": "^4.0.0",
    "dictionary-es": "^4.0.0",
    "dictionary-fr": "^3.0.0",
    "dictionary-pt-br": "^3.0.0",
    "dompurify": "^3.4.11",
    "jsdom": "^29.1.1",
    "nspell": "^2.1.5",
    "pdfjs-dist": "^5.6.205"
  }
}
